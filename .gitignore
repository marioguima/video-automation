# === VizLec .gitignore ===

# OS / Editor
.DS_Store
Thumbs.db
*.swp
*.swo
*.tmp
*.bak
.vscode/
.idea/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Node / TS
node_modules/
**/node_modules/
dist/
**/dist/
build/
**/build/
.out/
**/.out/
.next/
**/.next/
.nuxt/
**/.nuxt/
.svelte-kit/
**/.svelte-kit/
coverage/
**/coverage/
*.tsbuildinfo

# Env files
.env
.env.*
!.env.example

# Package manager caches
.pnpm-store/
.pnp.*
.yarn/cache/
.yarn/unplugged/
.yarn/build-state.yml
.yarn/install-state.gz

# Playwright
playwright-report/
playwright/.cache/
**/playwright-report/
**/.playwright/
**/ms-playwright/

# Electron
release/
releases/
out/
**/out/
*.exe
*.dmg
*.app
*.msi
*.AppImage
*.snap

# Runtime data (generated assets)
# IMPORTANT: keep generated media and DB out of git.
data/
**/data/
*.sqlite
*.sqlite3
*.db
data/courses/
data/courses/**

# Generated media assets
*.mp4
*.mov
*.mkv
*.wav
*.mp3
*.png
*.jpg
*.jpeg
*.webp

# If you later decide to version some sample assets, whitelist them explicitly:
# !assets/samples/**

# Python (if used for tooling/scripts)
__pycache__/
*.py[cod]
.venv/
venv/
.venv*

# Temporary helper files
/tmp_rovodev_*
tmp/
_delete_later_migration_node_modules/
