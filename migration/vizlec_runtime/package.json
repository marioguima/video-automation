{
  "name": "vizlec",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "pnpm --filter @vizlec/api dev",
    "dev:worker": "pnpm --filter @vizlec/worker dev",
    "dev:web": "pnpm --filter @vizlec/web dev",
    "dev:api:sandbox": "pnpm --filter @vizlec/api dev",
    "dev:worker:sandbox": "pnpm --filter @vizlec/worker dev",
    "dev:web:sandbox": "set WEB_PORT=4273&& set VITE_API_BASE=http://127.0.0.1:4110&& pnpm --filter @vizlec/web dev",
    "storage:migrate:dry-run": "node scripts/migrate-storage-domain-root.cjs",
    "storage:migrate:copy": "node scripts/migrate-storage-domain-root.cjs --apply",
    "storage:migrate:move": "node scripts/migrate-storage-domain-root.cjs --move",
    "storage:migrate:copy:force": "node scripts/migrate-storage-domain-root.cjs --apply --force",
    "storage:migrate:move:force": "node scripts/migrate-storage-domain-root.cjs --move --force",
    "db:domain-rename:dry-run": "node scripts/prisma-domain-physical-rename-sqlite.cjs",
    "db:domain-rename:apply": "node scripts/prisma-domain-physical-rename-sqlite.cjs --apply",
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "verify:critical": "pnpm --filter @vizlec/api typecheck && pnpm --filter @vizlec/web typecheck && pnpm --filter @vizlec/api run test:one -- test/correlation-id-traceability.test.ts",
    "setup:hooks": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-hooks.ps1",
    "db:migrate": "node scripts/prisma-migrate.cjs"
  }
}
