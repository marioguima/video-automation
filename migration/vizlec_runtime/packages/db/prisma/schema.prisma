generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         String   @default("member")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships WorkspaceMembership[]
  sentInvites Invitation[]        @relation("InviteCreatedBy")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships WorkspaceMembership[]
  agents      Agent[]
  invitations Invitation[]
  channels       Channel[]
  sections       Section[]
  videos         Video[]
  videoVersions  VideoVersion[]
  blocks      Block[]
  assets      Asset[]
  jobs        Job[]
  notifications Notification[]
}

model WorkspaceMembership {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String
  role        String   @default("member")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Agent {
  id                String    @id @default(cuid())
  workspaceId       String
  label             String?
  machineFingerprint String?
  status            String    @default("offline")
  lastSeenAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
}

model Invitation {
  id              String   @id @default(cuid())
  workspaceId     String
  inviteeName     String?
  email           String
  role            String
  tokenHash       String   @unique
  expiresAt       DateTime
  revokedAt       DateTime?
  acceptedAt      DateTime?
  createdAt       DateTime @default(now())
  invitedByUserId String

  invitedBy User      @relation("InviteCreatedBy", fields: [invitedByUserId], references: [id])
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([email, createdAt])
  @@index([expiresAt, revokedAt, acceptedAt])
}

model Channel {
  id                  String   @id @default(cuid())
  workspaceId         String
  name                String
  description         String?
  categoryId          String?
  productLanguage     String?
  emailLanguage       String?
  primarySalesCountry String?
  salesPageUrl        String?
  imageAssetId        String?
  status              String   @default("draft")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sections  Section[]

  @@index([workspaceId, createdAt])
}

model SlideTemplate {
  id        String   @id
  label     String
  kind      String
  fileName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([isActive])
}

model Section {
  id        String   @id @default(cuid())
  workspaceId String
  channelId String
  name      String
  order     Int
  createdAt DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  channel    Channel   @relation(fields: [channelId], references: [id])
  videos     Video[]

  @@index([channelId, order])
  @@index([workspaceId, channelId, order])
}

model Video {
  id        String   @id @default(cuid())
  workspaceId String
  sectionId String
  order     Int
  title     String
  createdAt DateTime @default(now())

  workspace Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  section   Section        @relation(fields: [sectionId], references: [id])
  videoVersions  VideoVersion[]

  @@index([sectionId, order])
  @@index([workspaceId, sectionId, order])
  @@unique([sectionId, order])
}

model VideoVersion {
  id                  String   @id @default(cuid())
  workspaceId         String
  videoId             String
  scriptText          String
  speechRateWps       Float    @default(2.5)
  preferredVoiceId    String?
  preferredTemplateId String?
  voiceVolume         Float?
  masterVolume        Float?
  bgmPath             String?
  bgmVolume           Float?
  createdAt           DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  video     Video     @relation(fields: [videoId], references: [id])
  blocks    Block[]
  jobs      Job[]

  @@index([workspaceId, videoId, createdAt])
  @@index([preferredTemplateId])
}

model Block {
  id                String   @id @default(cuid())
  workspaceId       String
  videoVersionId    String
  index             Int
  sourceText        String
  ttsText           String
  wordCount         Int
  durationEstimateS Float
  audioDurationS    Float?
  /// JSON string (title + bullets)
  onScreenJson      String?
  /// JSON string (block_prompt, avoid, seed_hint)
  imagePromptJson   String?
  /// ms spent generating on-screen + image prompt (LLM)
  segmentMs         Int?
  /// last segmentation error (if any)
  segmentError      String?
  status            String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videoVersion VideoVersion @relation(fields: [videoVersionId], references: [id])
  assets        Asset[]
  jobs          Job[]

  @@index([videoVersionId, index])
  @@index([workspaceId, videoVersionId, index])
  @@map("Block")
}

model Asset {
  id        String    @id @default(cuid())
  workspaceId String
  blockId   String
  /// String enum: audio_raw | image_raw | slide_png | clip_mp4 | final_mp4 | manifest_json
  kind      String
  path      String
  sha256    String?
  /// JSON string metadata
  metaJson  String?
  templateId String?
  createdAt DateTime  @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  block     Block     @relation(fields: [blockId], references: [id])

  @@index([blockId, kind])
  @@index([workspaceId, blockId, kind])
  @@index([templateId])
  @@map("Asset")
}

model Job {
  id              String    @id @default(cuid())
  workspaceId     String
  /// String enum: video_version | block
  scope           String
  videoVersionId String?
  blockId         String?
  /// String enum: segment | image_prompt | tts | probe_audio | comfyui_image | render_clip | concat_video | ...
  type            String
  /// String enum: pending | running | succeeded | failed | canceled
  status          String    @default("pending")
  attempts        Int       @default(0)
  error           String?
  inputHash       String?
  priority        Int       @default(0)
  clientId        String?
  requestId       String?
  /// JSON string metadata (job options, flags, etc.)
  metaJson        String?
  leaseExpiresAt  DateTime?
  canceledAt      DateTime?
  templateId      String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  workspace    Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  videoVersion VideoVersion? @relation(fields: [videoVersionId], references: [id])
  block         Block?         @relation(fields: [blockId], references: [id])

  @@index([status, priority])
  @@index([workspaceId, status, priority])
  @@index([videoVersionId])
  @@index([blockId])
  @@index([workspaceId, createdAt])
  @@index([templateId])
  @@map("Job")
}

model Notification {
  id              String   @id @default(cuid())
  workspaceId     String
  title           String
  message         String
  type            String
  read            Boolean  @default(false)
  jobId           String?
  jobType         String?
  jobStatus       String?
  videoId         String?
  videoVersionId  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, read, createdAt])
  @@index([read, createdAt])
  @@index([jobId, jobStatus])
  @@index([videoId])
}
