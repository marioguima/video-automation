Dialogue: 0,0:00:00.00,0:00:03.70,Default,,0,0,0,,SE ELA PAROU DE RESPONDER ANTES\NDE QUALQUER COISA, RESPIRA.
Dialogue: 0,0:00:04.30,0:00:06.60,Default,,0,0,0,,EU SEI O QUE ACONTECE NA\NSUA CABEÇA NESSA HORA.
Dialogue: 0,0:00:07.04,0:00:09.40,Default,,0,0,0,,VOCÊ PEGA O CELULAR DE 5 EM 5 MINUTOS.
Dialogue: 0,0:00:09.68,0:00:11.54,Default,,0,0,0,,FICA RELENDO A ÚLTIMA MENSAGEM.
Dialogue: 0,0:00:11.76,0:00:12.42,Default,,0,0,0,,COMEÇA A PENSAR.
Dialogue: 0,0:00:12.70,0:00:13.88,Default,,0,0,0,,SERÁ QUE EU FALEI BESTEIRA?
Dialogue: 0,0:00:14.12,0:00:14.96,Default,,0,0,0,,SERÁ QUE EXAGEREI?
Dialogue: 0,0:00:15.30,0:00:16.68,Default,,0,0,0,,SERÁ QUE ELA PERDEU O INTERESSE?
Dialogue: 0,0:00:16.94,0:00:20.20,Default,,0,0,0,,E QUANTO MAIS VOCÊ PENSA, MAIS\NDÁ VONTADE DE FAZER ALGUMA COISA.
Dialogue: 0,0:00:20.36,0:00:21.66,Default,,0,0,0,,MANDAR OUTRA MENSAGEM.
Dialogue: 0,0:00:21.78,0:00:23.02,Default,,0,0,0,,PERGUNTAR SE ESTÁ TUDO BEM.
Dialogue: 0,0:00:23.36,0:00:25.96,Default,,0,0,0,,FINGIR QUE NÃO ACONTECEU\NNADA E PUXAR OUTRO ASSUNTO.
Dialogue: 0,0:00:26.52,0:00:27.10,Default,,0,0,0,,OU PIOR.
Dialogue: 0,0:00:27.76,0:00:30.12,Default,,0,0,0,,MANDAR UM TEXTÃO EXPLICANDO\NOS SEUS SENTIMENTOS.
Dialogue: 0,0:00:30.28,0:00:32.16,Default,,0,0,0,,E DEIXA EU TE FALAR UMA\NCOISA COM HONESTIDADE.
Dialogue: 0,0:00:32.56,0:00:35.14,Default,,0,0,0,,É EXATAMENTE ISSO QUE TE\NCOLOCA NUMA POSIÇÃO FRACA.
Dialogue: 0,0:00:35.36,0:00:37.04,Default,,0,0,0,,NÃO É O SILÊNCIO DELA QUE TE PREJUDICA.
Dialogue: 0,0:00:37.30,0:00:38.64,Default,,0,0,0,,É A SUA REAÇÃO AO SILÊNCIO.
Dialogue: 0,0:00:38.76,0:00:43.22,Default,,0,0,0,,PORQUE QUANDO VOCÊ REAGE NO IMPULSO, VOCÊ\NMOSTRA QUE ESTÁ MAIS INTERESSADO QUE ELA
Dialogue: 0,0:00:43.22,0:00:43.98,Default,,0,0,0,,NAQUELE MOMENTO.
Dialogue: 0,0:00:44.50,0:00:46.64,Default,,0,0,0,,E QUANDO ISSO ACONTECE, A DINÂMICA MUDA.
Dialogue: 0,0:00:46.78,0:00:50.18,Default,,0,0,0,,VOCÊ SAI DA POSIÇÃO DE ESCOLHA\NE ENTRA NA POSIÇÃO DE ESPERA.
Dialogue: 0,0:00:50.66,0:00:52.66,Default,,0,0,0,,E NINGUÉM QUER SER O\NCARA QUE ESTÁ ESPERANDO.
Dialogue: 0,0:00:53.42,0:00:55.44,Default,,0,0,0,,AGORA PRESTA ATENÇÃO NO QUE VOU TE DIZER.
Dialogue: 0,0:00:55.44,0:00:59.42,Default,,0,0,0,,QUANDO UMA MULHER PARA DE RESPONDER,\NISSO PODE SIGNIFICAR VÁRIAS COISAS.
Dialogue: 0,0:00:59.74,0:01:01.40,Default,,0,0,0,,PODE SER QUE ELA ESTEJA OCUPADA.
Dialogue: 0,0:01:01.56,0:01:03.46,Default,,0,0,0,,PODE SER QUE TENHA PERDIDO\NUM POUCO DO INTERESSE.
Dialogue: 0,0:01:03.68,0:01:06.86,Default,,0,0,0,,PODE SER QUE ESTEJA TESTANDO O\NSEU NÍVEL DE CONTROLE EMOCIONAL.
Dialogue: 0,0:01:07.24,0:01:09.72,Default,,0,0,0,,PODE SER QUE TENHA OUTRA\NOPÇÃO CHAMANDO ATENÇÃO.
Dialogue: 0,0:01:10.12,0:01:13.94,Default,,0,0,0,,MAS NENHUMA DESSAS SITUAÇÕES MELHORA\NQUANDO VOCÊ DEMONSTRA ANSIEDADE.
Dialogue: 0,0:01:14.12,0:01:15.02,Default,,0,0,0,,TEXTÃO NÃO RESOLVE.
Dialogue: 0,0:01:15.36,0:01:16.44,Default,,0,0,0,,COBRANÇA NÃO RESOLVE.
Dialogue: 0,0:01:16.68,0:01:17.28,Default,,0,0,0,,TÁ TUDO BEM?
Dialogue: 0,0:01:17.44,0:01:18.06,Default,,0,0,0,,NÃO RESOLVE.
Dialogue: 0,0:01:18.32,0:01:19.18,Default,,0,0,0,,IRONIA NÃO RESOLVE.
Dialogue: 0,0:01:19.44,0:01:21.40,Default,,0,0,0,,MANDAR MEME PRA QUEBRAR O CLIMA NÃO RESOLVE.
Dialogue: 0,0:01:21.40,0:01:26.48,Default,,0,0,0,,NA VERDADE, QUANTO MAIS VOCÊ TENTA RESOLVER,\NMAIS VOCÊ REFORÇA QUE ESTÁ INCOMODADO.
Dialogue: 0,0:01:26.66,0:01:27.58,Default,,0,0,0,,E ISSO PESA.
Dialogue: 0,0:01:27.82,0:01:30.78,Default,,0,0,0,,ENTÃO QUAL É A ATITUDE\NMADURA QUE VOCÊ NÃO FAZ NADA.
Dialogue: 0,0:01:31.20,0:01:32.82,Default,,0,0,0,,MAS NÃO É NADA DE DESESPERO.
Dialogue: 0,0:01:32.96,0:01:33.88,Default,,0,0,0,,É NADA DE CONTROLE.
Dialogue: 0,0:01:34.54,0:01:37.38,Default,,0,0,0,,VOCÊ NÃO MANDA MENSAGEM\NPOR PELO MENOS 24 HORAS.
Dialogue: 0,0:01:37.94,0:01:39.22,Default,,0,0,0,,NÃO POSTA HISTÓRIA EMOCIONAL.
Dialogue: 0,0:01:39.36,0:01:40.52,Default,,0,0,0,,NÃO COLOCA EM DIRETA.
Dialogue: 0,0:01:40.80,0:01:42.48,Default,,0,0,0,,NÃO TENTA APARECER DE QUALQUER FORMA.
Dialogue: 0,0:01:42.70,0:01:44.60,Default,,0,0,0,,VOCÊ SIMPLESMENTE VOLTA PRA SUA VIDA.
Dialogue: 0,0:01:44.86,0:01:45.24,Default,,0,0,0,,TREINA.
Dialogue: 0,0:01:45.50,0:01:46.02,Default,,0,0,0,,TRABALHA.
Dialogue: 0,0:01:46.26,0:01:47.02,Default,,0,0,0,,SAI COM AMIGOS.
Dialogue: 0,0:01:47.02,0:01:48.36,Default,,0,0,0,,FAÇA SUAS COISAS.
Dialogue: 0,0:01:48.64,0:01:51.04,Default,,0,0,0,,PORQUE TEM UMA COISA QUE\NVOCÊ PRECISA ENTENDER.
Dialogue: 0,0:01:51.54,0:01:55.46,Default,,0,0,0,,QUANDO VOCÊ CORRE ATRÁS DO SILÊNCIO\NDELA, VOCÊ VAI ALI DO SILÊNCIO.
Dialogue: 0,0:01:55.60,0:01:57.84,Default,,0,0,0,,QUANDO VOCÊ NÃO REAGE, VOCÊ CRIA ESPAÇO.
Dialogue: 0,0:01:58.18,0:02:00.32,Default,,0,0,0,,E ESPAÇO É O QUE PERMITE\NQUE ELA SINTA AUSÊNCIA.
Dialogue: 0,0:02:00.74,0:02:02.22,Default,,0,0,0,,AGORA, DEIXA EU SER BEM CLARO.
Dialogue: 0,0:02:02.40,0:02:03.46,Default,,0,0,0,,ISSO NÃO É JOGUINHO.
Dialogue: 0,0:02:03.70,0:02:04.54,Default,,0,0,0,,ISSO É POSTURA.
Dialogue: 0,0:02:04.80,0:02:08.04,Default,,0,0,0,,SE ELA REALMENTE TIVER INTERESSE,\NELA VAI SENTIR A MUDANÇA.
Dialogue: 0,0:02:08.22,0:02:12.26,Default,,0,0,0,,SE ELA NÃO TIVER, INSISTIR SÓ VAI\NPROLONGAR ALGO QUE JÁ ESTAVA FRACO.
Dialogue: 0,0:02:12.38,0:02:14.56,Default,,0,0,0,,E AQUI ESTÁ O PONTO QUE QUASE NINGUÉM FALA.
Dialogue: 0,0:02:14.56,0:02:17.16,Default,,0,0,0,,O OBJETIVO NÃO É FAZER ELA RESPONDER.
Dialogue: 0,0:02:17.70,0:02:21.22,Default,,0,0,0,,O OBJETIVO É VOCÊ NÃO SE DIMINUIR\NTENTANDO FORÇAR A RESPOSTA.
Dialogue: 0,0:02:21.54,0:02:23.02,Default,,0,0,0,,EXISTE UMA DIFERENÇA ENORME.
Dialogue: 0,0:02:23.34,0:02:26.38,Default,,0,0,0,,PORQUE QUANDO VOCÊ TENTA\NFORÇAR, VOCÊ SE DESVALORIZA.
Dialogue: 0,0:02:26.54,0:02:29.16,Default,,0,0,0,,QUANDO VOCÊ SEGURA, VOCÊ\NPRESERVA SUA POSIÇÃO.
Dialogue: 0,0:02:29.40,0:02:33.90,Default,,0,0,0,,DEPOIS DESSAS 24 HORAS, VOCÊ PODE\NMANDAR ALGO SIMPLES, DIRETO, CURTO.
Dialogue: 0,0:02:34.10,0:02:35.10,Default,,0,0,0,,SEM EMOÇÃO DEMAIS.
Dialogue: 0,0:02:35.48,0:02:36.20,Default,,0,0,0,,SEM COBRANÇA.
Dialogue: 0,0:02:36.80,0:02:39.48,Default,,0,0,0,,MAS ISSO PRECISA SER\NFEITO COM A CABEÇA FRIA.
Dialogue: 0,0:02:39.58,0:02:42.04,Default,,0,0,0,,E A MAIORIA ERRA EXATAMENTE AQUI.
Dialogue: 0,0:02:42.48,0:02:43.56,Default,,0,0,0,,AGE NO IMPULSO.
Dialogue: 0,0:02:43.56,0:02:44.94,Default,,0,0,0,,AGE NA CARÊNCIA.
Dialogue: 0,0:02:45.20,0:02:46.42,Default,,0,0,0,,AGE NO MEDO DE PERDER.
Dialogue: 0,0:02:46.86,0:02:51.12,Default,,0,0,0,,E SE VOCÊ ESTÁ PASSANDO POR ISSO AGORA,\NEU SEI COMO É FÁCIL PERDER A CABEÇA.
Dialogue: 0,0:02:51.30,0:02:53.34,Default,,0,0,0,,QUANDO ISSO ACONTECEU\NCOMIGO, EU FIZ TUDO ERRADO.
Dialogue: 0,0:02:53.78,0:02:54.64,Default,,0,0,0,,MENSAGEM DEMAIS.
Dialogue: 0,0:02:54.98,0:02:56.00,Default,,0,0,0,,ANSIEDADE DEMAIS.
Dialogue: 0,0:02:56.60,0:02:57.20,Default,,0,0,0,,E SÓ PIOROU.
Dialogue: 0,0:02:57.42,0:03:01.80,Default,,0,0,0,,DEPOIS DISSO, EU PAREI E ORGANIZEI PRA\NMIM MESMO UM PASSO A PASSO SIMPLES DO QUE
Dialogue: 0,0:03:01.80,0:03:04.08,Default,,0,0,0,,FAZER QUANDO UMA MULHER COMEÇA A ESFRIAR.
Dialogue: 0,0:03:04.20,0:03:05.94,Default,,0,0,0,,JUSTAMENTE PRA NÃO AGIR NO IMPULSO.
Dialogue: 0,0:03:06.02,0:03:08.78,Default,,0,0,0,,EU DEIXEI ESSE MESMO GUIA NO\NPRIMEIRO COMENTÁRIO FIXADO.
Dialogue: 0,0:03:09.04,0:03:12.28,Default,,0,0,0,,SE VOCÊ ESTIVER NESSA FASE, PODE\NTE AJUDAR A MANTER A POSTURA.
Dialogue: 0,0:03:12.28,0:03:15.28,Default,,0,0,0,,PORQUE AGIR SEM PLANO, É O\NQUE MAIS DESTRÓI SUAS CHANCES.
Dialogue: 0,0:03:15.52,0:03:18.40,Default,,0,0,0,,E O QUE VOCÊ PRECISA AGORA\NNÃO É DESESPERO, É CONTROLE.
