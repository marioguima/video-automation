# VizLec environment example (development and lab)
# Canonical source for environment variables used by API/Worker/Shared runtime.
# Rule: keep secrets out of git and replace placeholder values before real usage.

# DATA_DIR
# Root directory for runtime data (database, assets, generated files, settings files).
DATA_DIR=G:\tool\video-automation\data

# API_HOST
# Bind host for API server.
API_HOST=127.0.0.1

# API_PORT
# HTTP port for API server.
API_PORT=4110

# WORKER_PORT
# HTTP port for worker health/internal endpoints.
WORKER_PORT=4111

# WEB_PORT
# Local dev port for frontend.
WEB_PORT=4273

# API_BASE_URL
# Base URL used by worker and installer to reach control plane.
API_BASE_URL=http://127.0.0.1:4110

# WEB_APP_BASE_URL
# Public URL used by API to build invite links.
WEB_APP_BASE_URL=http://127.0.0.1:4273

# AUTH_JWT_SECRET
# Secret used to sign/authenticate session JWT.
AUTH_JWT_SECRET=change-me-in-production

# AUTH_COOKIE_SECURE
# true in HTTPS environments; false only for local HTTP development.
AUTH_COOKIE_SECURE=false

# INTERNAL_JOBS_EVENT_TOKEN
# Internal token for trusted API<->worker internal HTTP endpoints.
INTERNAL_JOBS_EVENT_TOKEN=change-me-in-production

# AGENT_CONTROL_TOKEN_SECRET
# Server-side secret used to sign/validate per-agent WS tokens (HMAC).
AGENT_CONTROL_TOKEN_SECRET=change-me-in-production

# AGENT_CONTROL_REQUEST_TIMEOUT_MS
# Timeout (ms) for API waiting worker WS command responses.
AGENT_CONTROL_REQUEST_TIMEOUT_MS=20000

# AGENT_PAIRING_TOKEN_TTL_MS
# Pairing token TTL (ms) for "add machine" onboarding.
AGENT_PAIRING_TOKEN_TTL_MS=600000

# AGENT_CONTROL_TOKEN
# Worker credential returned by /agent-control/validate-worker.
# Dev/lab only in .env. In client distribution, store in local OS secure store.
AGENT_CONTROL_TOKEN=

# WORKSPACE_ID
# Worker workspace identity returned by /agent-control/validate-worker.
WORKSPACE_ID=

# AGENT_ID
# Worker agent identity returned by /agent-control/validate-worker.
AGENT_ID=

# AGENT_LABEL
# Optional friendly machine name shown in UI/logs.
AGENT_LABEL=

# MACHINE_FINGERPRINT
# Stable machine identifier sent during pairing/hello.
MACHINE_FINGERPRINT=

# WORKER_INVENTORY_SCAN_INTERVAL_MS
# Worker inventory collector periodic scan interval (ms).
WORKER_INVENTORY_SCAN_INTERVAL_MS=30000

# WORKER_REQUIRE_WS_ON_STARTUP
# true => worker falha no startup se nao atingir WS ready (agent_hello_ack) no timeout.
# false => worker sobe para diagnostico mesmo sem WS pronto.
WORKER_REQUIRE_WS_ON_STARTUP=false

# WORKER_WS_STARTUP_TIMEOUT_MS
# Timeout (ms) para aguardar WS ready no startup quando WORKER_REQUIRE_WS_ON_STARTUP=true.
WORKER_WS_STARTUP_TIMEOUT_MS=45000

# JOB_MAX_ATTEMPTS
# Max retries per job before hard fail.
JOB_MAX_ATTEMPTS=3

# JOB_LEASE_MS
# Lease duration (ms) for running job ownership.
JOB_LEASE_MS=30000

# JOB_LEASE_HEARTBEAT_MS
# Lease heartbeat interval (ms) while job is running.
JOB_LEASE_HEARTBEAT_MS=10000

# JOB_STALE_AFTER_MS
# Stale job threshold (ms) for recovery logic in API/Worker.
JOB_STALE_AFTER_MS=600000

# OLLAMA_BASE_URL
# Local/base URL for Ollama provider.
OLLAMA_BASE_URL=http://127.0.0.1:11434

# OLLAMA_MODEL
# Default LLM model identifier for generation.
OLLAMA_MODEL=qwen3:8b

# OLLAMA_TIMEOUT_MS
# Request timeout (ms) for Ollama calls.
OLLAMA_TIMEOUT_MS=300000

# COMFYUI_BASE_URL
# Local/base URL for ComfyUI provider.
COMFYUI_BASE_URL=http://127.0.0.1:8188

# COMFY_PROMPT_TIMEOUT_MS
# Timeout (ms) for ComfyUI prompt submission.
COMFY_PROMPT_TIMEOUT_MS=60000

# COMFY_GENERATION_TIMEOUT_MS
# Timeout (ms) for ComfyUI generation completion.
COMFY_GENERATION_TIMEOUT_MS=300000

# COMFY_VIEW_TIMEOUT_MS
# Timeout (ms) for ComfyUI image/file fetch.
COMFY_VIEW_TIMEOUT_MS=60000

# COMFY_SETTINGS_PATH
# Optional custom path for persisted ComfyUI settings.
COMFY_SETTINGS_PATH=G:\tool\vizlec\data\comfy_settings.json

# APP_SETTINGS_PATH
# Optional custom path for app-level runtime settings snapshot.
APP_SETTINGS_PATH=G:\tool\vizlec\data\app_settings.json

# TTS_PROVIDER
# Active TTS provider: qwen | xtts | xtts_api | chatterbox.
TTS_PROVIDER=xtts

# TTS_TIMEOUT_US
# Legacy TTS timeout in microseconds (API runtime compatibility path).
TTS_TIMEOUT_US=5000000

# TTS_VOICES_DIR
# Directory containing local voices/speakers assets.
TTS_VOICES_DIR=G:\tool\vizlec\data\voices

# TTS_VOICES_INDEX
# JSON index file for voices catalog.
TTS_VOICES_INDEX=G:\tool\vizlec\data\voices.json

# TTS_SETTINGS_PATH
# JSON settings file for selected voice/language.
TTS_SETTINGS_PATH=G:\tool\vizlec\data\tts_settings.json

# XTTS_API_BASE_URL
# Base URL for XTTS API server.
XTTS_API_BASE_URL=http://127.0.0.1:8020

# XTTS_API_PYTHON
# Python executable used to boot XTTS API.
XTTS_API_PYTHON=G:\tool\vizlec\.venv-tts-xtts\Scripts\python.exe

# XTTS_API_SERVER_DIR
# XTTS API server source directory.
XTTS_API_SERVER_DIR=G:\projects\back-end\xtts-api-server

# XTTS_API_MODEL_DIR
# Directory for XTTS model files.
XTTS_API_MODEL_DIR=G:\tool\vizlec\data\xtts_models

# XTTS_API_SPEAKER_DIR
# Directory for XTTS speakers/voices.
XTTS_API_SPEAKER_DIR=G:\tool\vizlec\data\voices

# XTTS_API_OUTPUT_DIR
# Directory for XTTS generated output files.
XTTS_API_OUTPUT_DIR=G:\tool\vizlec\data\xtts_output

# XTTS_API_MODEL_SOURCE
# XTTS model source mode (local or remote strategy).
XTTS_API_MODEL_SOURCE=local

# XTTS_API_MODEL_VERSION
# XTTS model version identifier.
XTTS_API_MODEL_VERSION=v2.0.2

# XTTS_API_DEVICE
# Runtime device for XTTS (cuda/cpu).
XTTS_API_DEVICE=cuda

# XTTS_API_USE_CACHE
# Enable/disable XTTS cache reuse.
XTTS_API_USE_CACHE=true

# XTTS_API_LOWVRAM
# XTTS low VRAM mode.
XTTS_API_LOWVRAM=false

# XTTS_API_DEEPSPEED
# XTTS deepspeed optimization flag.
XTTS_API_DEEPSPEED=false

# XTTS_API_AUTOSTART
# Auto start XTTS API process on demand.
XTTS_API_AUTOSTART=true

# XTTS_API_DETACH
# Detach XTTS API process after startup.
XTTS_API_DETACH=false

# XTTS_API_START_TIMEOUT_MS
# XTTS API boot timeout (ms).
XTTS_API_START_TIMEOUT_MS=900000

# XTTS_API_REQUEST_TIMEOUT_MS
# XTTS API request timeout (ms).
XTTS_API_REQUEST_TIMEOUT_MS=600000

# XTTS_HEALTH_TIMEOUT_MS
# Timeout (ms) for XTTS healthcheck probing.
XTTS_HEALTH_TIMEOUT_MS=8000

# XTTS_HEALTH_MAX_ATTEMPTS
# Max retry attempts for XTTS healthcheck.
XTTS_HEALTH_MAX_ATTEMPTS=2

# XTTS_LANGUAGE
# Default XTTS language code.
XTTS_LANGUAGE=pt

# XTTS_VOICE_ID
# Default XTTS speaker/voice id.
XTTS_VOICE_ID=cohesive-pt-santiago-22050hz

# QWEN_TTS_BASE_URL
# Base URL for Qwen TTS service.
QWEN_TTS_BASE_URL=http://127.0.0.1:9000

# QWEN_TTS_MODEL
# Qwen TTS model identifier.
QWEN_TTS_MODEL=Qwen/Qwen3-TTS-12Hz-0.6B-CustomVoice

# QWEN_TTS_TASK
# Qwen TTS task mode.
QWEN_TTS_TASK=custom_voice

# QWEN_TTS_SPEAKER
# Default Qwen speaker.
QWEN_TTS_SPEAKER=Ryan

# QWEN_TTS_LANGUAGE
# Default Qwen language mode.
QWEN_TTS_LANGUAGE=Auto

# QWEN_TTS_INSTRUCT
# Optional instruction text for Qwen synthesis.
QWEN_TTS_INSTRUCT=

# QWEN_TTS_DEVICE
# Runtime device for Qwen TTS.
QWEN_TTS_DEVICE=cuda:0

# QWEN_TTS_DTYPE
# Numeric precision dtype for Qwen TTS.
QWEN_TTS_DTYPE=bfloat16

# QWEN_TTS_ATTN_IMPLEMENTATION
# Attention implementation for Qwen TTS runtime.
QWEN_TTS_ATTN_IMPLEMENTATION=flash_attention_2

# QWEN_TTS_PYTHON
# Python executable for Qwen TTS scripts.
QWEN_TTS_PYTHON=python

# CHATTERBOX_PYTHON
# Python executable for Chatterbox scripts.
CHATTERBOX_PYTHON=python

# CHATTERBOX_DEVICE
# Runtime device for Chatterbox.
CHATTERBOX_DEVICE=cuda

# CHATTERBOX_LANGUAGE
# Default Chatterbox language.
CHATTERBOX_LANGUAGE=pt

# CHATTERBOX_VOICE_ID
# Default Chatterbox voice id.
CHATTERBOX_VOICE_ID=h-adulto-grave

# CHATTERBOX_EXAGGERATION
# Chatterbox expression/exaggeration level.
CHATTERBOX_EXAGGERATION=0.5

# CHATTERBOX_TEMPERATURE
# Chatterbox temperature parameter.
CHATTERBOX_TEMPERATURE=0.8

# CHATTERBOX_CFG_WEIGHT
# Chatterbox CFG guidance weight.
CHATTERBOX_CFG_WEIGHT=0.5

# VIZLEC_DB_URL
# Optional explicit Prisma database URL. Usually auto-derived from DATA_DIR.
# Example: file:G:/tool/vizlec/data/vizlec.db
VIZLEC_DB_URL=

# VIZLEC_SKIP_API_LISTEN
# true disables API listen() in direct execution (mainly tests/tooling).
VIZLEC_SKIP_API_LISTEN=false

# GEMINI_API_KEY
# Optional key used by apps/web-v2 build/runtime path.
GEMINI_API_KEY=
